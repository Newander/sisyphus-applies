POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

JOB_TRACKER_STORAGE_DIR=storage/documents
FRONTEND_ORIGIN=http://localhost:3000
LOG_LEVEL=INFO

GOOGLE_CLIENT_SECRET_FILE=credentials/client_secret.json
GOOGLE_GMAIL_TOKEN_FILE=credentials/gmail_token.json
GMAIL_INITIAL_SYNC_QUERY=newer_than:180d

CODEX_CLI_COMMAND=codex
CODEX_CLI_ARGS=exec -
CODEX_CLI_TIMEOUT_SECONDS=120
CODEX_BRIDGE_PROMPT_FILE=backend/prompts/codex_bridge.md
CODEX_JOB_EXTRACTION_PROMPT_FILE=backend/prompts/job_post_extraction.md

# SSH sync (optional — оставь пустыми, если синк не нужен)
# SSH_SYNC_HOST=192.168.1.100
# SSH_SYNC_PORT=22
# SSH_SYNC_USER=myuser
# SSH_SYNC_KEY_FILE=~/.ssh/id_rsa
# SSH_SYNC_REMOTE_DIR=/c/Users/myuser/Documents/job-tracker
# SSH_SYNC_INTERVAL_SECONDS=300

# dev → uvicorn --reload, next dev (HMR). prod → uvicorn без reload, next build && next start.
APP_ENV=dev
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
# Пусто → frontend ходит относительными путями /api/... (их разводит Caddy).
NEXT_PUBLIC_API_BASE_URL=
FRONTEND_ORIGIN=http://localhost:3000
