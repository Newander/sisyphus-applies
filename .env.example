POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

JOB_TRACKER_STORAGE_DIR=storage/documents
LOG_LEVEL=INFO

CODEX_CLI_COMMAND=codex
CODEX_CLI_ARGS=exec -
CODEX_CLI_TIMEOUT_SECONDS=120
CODEX_BRIDGE_PROMPT_FILE=backend/prompts/codex_bridge.md
CODEX_JOB_EXTRACTION_PROMPT_FILE=backend/prompts/job_post_extraction.md

# SSH sync (optional — leave empty if not needed)
# SSH_SYNC_HOST=192.168.1.100
# SSH_SYNC_PORT=22
# SSH_SYNC_USER=myuser
# SSH_SYNC_KEY_FILE=~/.ssh/id_rsa
# SSH_SYNC_REMOTE_DIR=/path/to/remote/job-tracker
# SSH_SYNC_INTERVAL_SECONDS=300

APP_ENV=dev
BACKEND_HOST=127.0.0.1
BACKEND_PORT=9002
FRONTEND_ORIGIN=http://localhost:9001
# Empty → frontend uses relative /api/... paths (proxied by Caddy in production).
# Set to http://127.0.0.1:9002 for direct local development without a proxy.
NEXT_PUBLIC_API_BASE_URL=
